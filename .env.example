# Tessera — environment variables
#
# 1. Copy this file to `.env.local` (gitignored)
# 2. Fill in real values from your Supabase dashboard
# 3. `docker compose up dev`
#
# In CI / Vercel, set these as Secrets / Environment Variables instead.

# Supabase project URL — Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (publishable) key — Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: VAPID public key for Web Push reminders.
# Generate with: `npx web-push generate-vapid-keys`
VITE_VAPID_PUBLIC_KEY=
