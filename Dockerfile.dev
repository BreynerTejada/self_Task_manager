# Dev container — Vite dev server with hot reload.
# Source is bind-mounted via docker-compose; only deps live inside the image.
FROM node:20-alpine

WORKDIR /app

# Tooling for native deps + healthier signal handling.
RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json ./
RUN npm ci

# Copy is intentional — bind-mount in compose overrides this for hot reload.
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
